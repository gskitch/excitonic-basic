---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { TransitionBeforePreparationEvent } from 'astro/virtual-modules/transitions-events.js';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div>
				<img width={480} height={220} src={"/excitonic-logo-swoosh-transparent.png"} alt="Excitonic Logo" />
			</div>
			<div style="height:100px"></div>
			<div>
				<h1>We make devices.</h1>
				<h3>Electronic<br>Photonic<br>Excitonic</h3>
				
			</div>
			<br style="clear:both">
		</main>
		<Footer />
	</body>
</html>
